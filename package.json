{
  "name": "moji",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "build": "tsc -b && vite build",
    "codecheck": "pnpm run typecheck && pnpm run lint",
    "deploy": "pnpm run build && wrangler deploy",
    "dev": "vite",
    "lint": "biome check",
    "lint:fix": "biome check --write",
    "preinstall": "npx only-allow pnpm",
    "preview": "wrangler dev",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@tiptap/react": "2.23.0",
    "@tiptap/starter-kit": "2.23.0",
    "dexie": "3.2.7",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-router-dom": "7.6.3"
  },
  "devDependencies": {
    "@biomejs/biome": "2.0.6",
    "@types/node": "24.0.10",
    "@types/react": "19.1.8",
    "@types/react-dom": "19.1.6",
    "@vitejs/plugin-react": "4.6.0",
    "typescript": "5.8.3",
    "vite": "7.0.0",
    "wrangler": "4.23.0"
  },
  "packageManager": "pnpm@11.14.0"
}
